# Copy to backend/.env and fill in. NEVER commit the real .env.

# MongoDB Atlas SRV connection string. URL-encode special chars in the password
# (e.g. '@' becomes %40). Database name: socialengine
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.za6egc1.mongodb.net/socialengine?retryWrites=true&w=majority

# Any long random string (used to sign JWTs)
JWT_SECRET=

# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# https://elevenlabs.io  -> Profile -> API Keys (voiceover / TTS)
ELEVENLABS_API_KEY=

# Zernio social-publishing key (may share the ElevenLabs key per current setup)
ZERNIO_API_KEY=

# https://www.ayrshare.com -> Dashboard -> API Key
AYRSHARE_API_KEY=

# Frontend origin (Vite dev server)
CLIENT_URL=http://localhost:5173
